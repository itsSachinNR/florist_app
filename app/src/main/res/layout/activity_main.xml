<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bloomify"
            android:textColor="#7A2E4D"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Simple flower ordering app"
            android:textColor="#8B5E74"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title" />

        <!-- ROSES -->
        <TextView
            android:id="@+id/roseText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Roses - ₹100"
            android:textColor="#5B2140"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitle" />

        <Button
            android:id="@+id/removeRose"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_small"
            android:backgroundTint="@null"
            android:onClick="removeRose"
            android:text="-"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/roseText" />

        <TextView
            android:id="@+id/roseQty"
            android:layout_width="50dp"
            android:layout_height="68dp"
            android:gravity="center"
            android:text="0"
            android:textColor="#5B2140"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/removeRose"
            app:layout_constraintStart_toEndOf="@id/removeRose"
            app:layout_constraintTop_toTopOf="@id/removeRose" />

        <Button
            android:id="@+id/addRose"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:background="@drawable/bg_button_small"
            android:backgroundTint="@null"
            android:onClick="addRose"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/roseQty"
            app:layout_constraintTop_toTopOf="@id/removeRose" />

        <!-- LILIES -->
        <TextView
            android:id="@+id/lilyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="Lilies - ₹120"
            android:textColor="#5B2140"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/removeRose" />

        <Button
            android:id="@+id/removeLily"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_small"
            android:backgroundTint="@null"
            android:onClick="removeLily"
            android:text="-"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lilyText" />

        <TextView
            android:id="@+id/lilyQty"
            android:layout_width="50dp"
            android:layout_height="68dp"
            android:gravity="center"
            android:text="0"
            android:textColor="#5B2140"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/removeLily"
            app:layout_constraintStart_toEndOf="@id/removeLily"
            app:layout_constraintTop_toTopOf="@id/removeLily" />

        <Button
            android:id="@+id/addLily"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:background="@drawable/bg_button_small"
            android:backgroundTint="@null"
            android:onClick="addLily"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/lilyQty"
            app:layout_constraintTop_toTopOf="@id/removeLily" />

        <!-- TULIPS -->
        <TextView
            android:id="@+id/tulipText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="Tulips - ₹150"
            android:textColor="#5B2140"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/removeLily" />

        <Button
            android:id="@+id/removeTulip"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_button_small"
            android:backgroundTint="@null"
            android:onClick="removeTulip"
            android:text="-"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tulipText" />

        <TextView
            android:id="@+id/tulipQty"
            android:layout_width="50dp"
            android:layout_height="68dp"
            android:gravity="center"
            android:text="0"
            android:textColor="#5B2140"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/removeTulip"
            app:layout_constraintStart_toEndOf="@id/removeTulip"
            app:layout_constraintTop_toTopOf="@id/removeTulip" />

        <Button
            android:id="@+id/addTulip"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:background="@drawable/bg_button_small"
            android:backgroundTint="@null"
            android:onClick="addTulip"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/tulipQty"
            app:layout_constraintTop_toTopOf="@id/removeTulip" />

        <TextView
            android:id="@+id/totalText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_total"
            android:gravity="center"
            android:padding="14dp"
            android:text="Estimated Total: ₹0"
            android:textColor="#7A2E4D"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/removeTulip" />

        <Button
            android:id="@+id/orderBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_button_primary"
            android:backgroundTint="@null"
            android:onClick="orderNow"
            android:padding="16dp"
            android:text="Place Order"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/totalText" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
