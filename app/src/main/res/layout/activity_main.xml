<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- TITLE -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bloomify 🌸"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#7A2E4D"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 🌹 ROSES -->
        <ImageView
            android:id="@+id/roseImg"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/rose"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/roseText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roses ₹100"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/roseImg"
            app:layout_constraintTop_toTopOf="@id/roseImg"
            android:layout_marginStart="16dp"/>

        <Button
            android:id="@+id/removeRose"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:text="-"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_small"
            android:backgroundTint="@null"
            android:onClick="removeRose"
            app:layout_constraintStart_toEndOf="@id/roseImg"
            app:layout_constraintTop_toBottomOf="@id/roseText"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"/>

        <TextView
            android:id="@+id/roseQty"
            android:layout_width="50dp"
            android:layout_height="70dp"
            android:text="0"
            android:textSize="20sp"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@id/removeRose"
            app:layout_constraintTop_toTopOf="@id/removeRose"/>

        <Button
            android:id="@+id/addRose"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:text="+"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_small"
            android:backgroundTint="@null"
            android:onClick="addRose"
            app:layout_constraintStart_toEndOf="@id/roseQty"
            app:layout_constraintTop_toTopOf="@id/removeRose"/>

        <!-- 🌼 LILIES -->
        <ImageView
            android:id="@+id/lilyImg"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/lilly"
            app:layout_constraintTop_toBottomOf="@id/removeRose"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="28dp"/>

        <TextView
            android:id="@+id/lilyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lilies ₹120"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/lilyImg"
            app:layout_constraintTop_toTopOf="@id/lilyImg"
            android:layout_marginStart="16dp"/>

        <Button
            android:id="@+id/removeLily"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:text="-"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_small"
            android:backgroundTint="@null"
            android:onClick="removeLily"
            app:layout_constraintStart_toEndOf="@id/lilyImg"
            app:layout_constraintTop_toBottomOf="@id/lilyText"
            android:layout_marginStart="16dp"/>

        <TextView
            android:id="@+id/lilyQty"
            android:layout_width="50dp"
            android:layout_height="70dp"
            android:text="0"
            android:gravity="center"
            android:textSize="20sp"
            app:layout_constraintStart_toEndOf="@id/removeLily"
            app:layout_constraintTop_toTopOf="@id/removeLily"/>

        <Button
            android:id="@+id/addLily"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:text="+"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_small"
            android:backgroundTint="@null"
            android:onClick="addLily"
            app:layout_constraintStart_toEndOf="@id/lilyQty"
            app:layout_constraintTop_toTopOf="@id/removeLily"/>

        <!-- 🌷 TULIPS -->
        <ImageView
            android:id="@+id/tulipImg"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/tulip"
            app:layout_constraintTop_toBottomOf="@id/removeLily"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="28dp"/>

        <TextView
            android:id="@+id/tulipText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tulips ₹150"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/tulipImg"
            app:layout_constraintTop_toTopOf="@id/tulipImg"
            android:layout_marginStart="16dp"/>

        <Button
            android:id="@+id/removeTulip"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:text="-"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_small"
            android:backgroundTint="@null"
            android:onClick="removeTulip"
            app:layout_constraintStart_toEndOf="@id/tulipImg"
            app:layout_constraintTop_toBottomOf="@id/tulipText"
            android:layout_marginStart="16dp"/>

        <TextView
            android:id="@+id/tulipQty"
            android:layout_width="50dp"
            android:layout_height="70dp"
            android:text="0"
            android:textSize="20sp"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@id/removeTulip"
            app:layout_constraintTop_toTopOf="@id/removeTulip"/>

        <Button
            android:id="@+id/addTulip"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:text="+"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_small"
            android:backgroundTint="@null"
            android:onClick="addTulip"
            app:layout_constraintStart_toEndOf="@id/tulipQty"
            app:layout_constraintTop_toTopOf="@id/removeTulip"/>

        <!-- TOTAL -->
        <TextView
            android:id="@+id/totalText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Total: ₹0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_total"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/removeTulip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="30dp"/>

        <!-- ORDER -->
        <Button
            android:id="@+id/orderBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Place Order"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_primary"
            android:backgroundTint="@null"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/totalText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
