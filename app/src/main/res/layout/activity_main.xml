<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="6dp"
            android:text="Bloomify"
            android:textColor="#7A2E4D"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:paddingBottom="18dp"
            android:text="Simple flower ordering app"
            android:textColor="#8B5E74"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Roses"
                android:textColor="#5B2140"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="₹100 each"
                android:textColor="#7F6674"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_button_small"
                    android:onClick="removeRose"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    tools:ignore="TouchTargetSizeCheck" />

                <TextView
                    android:id="@+id/roseQty"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#5B2140"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_button_small"
                    android:onClick="addRose"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    tools:ignore="TouchTargetSizeCheck" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lilies"
                android:textColor="#5B2140"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="₹120 each"
                android:textColor="#7F6674"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_button_small"
                    android:onClick="removeLily"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    tools:ignore="TouchTargetSizeCheck" />

                <TextView
                    android:id="@+id/lilyQty"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#5B2140"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_button_small"
                    android:onClick="addLily"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    tools:ignore="TouchTargetSizeCheck" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tulips"
                android:textColor="#5B2140"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="₹150 each"
                android:textColor="#7F6674"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_button_small"
                    android:onClick="removeTulip"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    tools:ignore="TouchTargetSizeCheck" />

                <TextView
                    android:id="@+id/tulipQty"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#5B2140"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_button_small"
                    android:onClick="addTulip"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    tools:ignore="TouchTargetSizeCheck" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/totalText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp"
            android:gravity="center"
            android:padding="14dp"
            android:background="@drawable/bg_total"
            android:text="Estimated Total: ₹0"
            android:textColor="#7A2E4D"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/orderBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_primary"
            android:padding="14dp"
            android:text="Place Order"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>